{
  "name": "real-estate-platform",
  "version": "0.1.0",
  "description": "A modern, full-featured real estate marketplace platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "echo 'Build script placeholder'",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "docker:build": "docker build -t real-estate-platform .",
    "docker:run": "docker run -p 3000:3000 --env-file .env real-estate-platform"
  },
  "keywords": [
    "real-estate",
    "property",
    "marketplace",
    "platform",
    "nodejs",
    "express"
  ],
  "author": "Uncle Scar <unclescar3@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.1",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "jest": "^29.6.1",
    "eslint": "^8.45.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "prettier": "^3.0.0",
    "nodemon": "^3.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unclescar3-hub/real-estate-platform.git"
  },
  "bugs": {
    "url": "https://github.com/unclescar3-hub/real-estate-platform/issues"
  },
  "homepage": "https://github.com/unclescar3-hub/real-estate-platform#readme"
}
